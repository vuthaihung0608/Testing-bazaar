#!/bin/bash

# Hungz Flipper Launcher Script
# This script helps users run the Hungz Flipper application

set -e

SCRIPT_DIR="$(cd "$(dirname "${BASH_SOURCE[0]}")" && pwd)"
cd "$SCRIPT_DIR"

# Check if the binary exists
if [ -f "target/release/hungz_flipper" ]; then
    echo "Running hungz_flipper..."
    exec ./target/release/hungz_flipper "$@"
elif [ -f "hungz_flipper" ]; then
    echo "Running hungz_flipper..."
    exec ./hungz_flipper "$@"
else
    echo "Binary not found. Building from source..."
    if ! command -v cargo &> /dev/null; then
        echo "Error: cargo is not installed. Please install Rust from https://rustup.rs/"
        exit 1
    fi
    
    echo "Building release binary..."
    cargo build --release
    
    echo "Build complete. Running hungz_flipper..."
    exec ./target/release/hungz_flipper "$@"
fi
